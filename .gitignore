# Ignore everything
*

# But not these files...
!.gitignore
!README.md
!.gitattributes
!.bashrc
!.xinitrc
!.vimrc
!.bash_profile
!.tmux.conf
!cloneVimPlugins
!status.sh
!.config

!.config/ghostty
!.config/ghostty/*

!.config/i3
!.config/i3/*

!.config/hypr
!.config/hypr/hyprland.conf

!.config/foot
!.config/foot/foot.ini

!.config/wezterm
!.config/wezterm/wezterm.lua

!.config/nvim
!.config/nvim/init.lua
!.config/nvim/.biome.json
!.config/nvim/.ols.json
!.config/nvim/.luarc.json

!.config/nvim/lsp
!.config/nvim/lsp/*

!.config/nvim/after
!.config/nvim/after/ftplugin
!.config/nvim/after/ftplugin/*

!.config/nvim/colors
!.config/nvim/colors/*

!.config/nvim/lua
!.config/nvim/lua/*
!.config/nvim/lua/plugins
!.config/nvim/lua/plugins/*
