__git_status_symbols() {
    git rev-parse --git-dir >/dev/null 2>&1 || return
    local s
    s=$(git status --porcelain=v2 --branch 2>/dev/null) || return
    local ahead=0 behind=0 con=0 unt=0 mod=0 sta=0 del=0
    while IFS= read -r line; do
        case $line in
            '# branch.ab +'*)
                local ab="${line#\# branch.ab +}"
                ahead=${ab%% -*}
                behind=${ab#* -}
                ;;
            'u '*) con=1 ;;
            '?'*) unt=1 ;;
            '1 '??' '*|'2 '??' '*)
                local x=${line:2:1} y=${line:3:1}
                [ "$x" != "." ] && sta=1
                [ "$y" = "M" ] && mod=1
                { [ "$x" = "D" ] || [ "$y" = "D" ]; } && del=1
                ;;
        esac
    done <<EOF
$s
EOF
    local sym=""
    [ "$con" -eq 1 ] && sym="${sym}="
    [ "$sta" -eq 1 ] && sym="${sym}+"
    [ "$mod" -eq 1 ] && sym="${sym}!"
    [ "$del" -eq 1 ] && sym="${sym}X"
    [ "$unt" -eq 1 ] && sym="${sym}?"
    if [ "$ahead" -gt 0 ] && [ "$behind" -gt 0 ]; then
        sym="${sym} ⇕"
    elif [ "$ahead" -gt 0 ]; then
        sym="${sym} ⇡"
    elif [ "$behind" -gt 0 ]; then
        sym="${sym} ⇣"
    fi
    [ -n "$sym" ] && printf " %s" "$sym"
}

PS1='[30m[42m $(pwd | sed "s|^$HOME|ᛟ|")$(git branch 2>/dev/null | sed -n "s/* / ᛇ /p")$(__git_status_symbols) [0m
ᚱ '

b0() {
    rfkill block bluetooth
    sudo systemctl stop bluetooth.service
}

b1() {
    rfkill unblock bluetooth
    sudo systemctl start bluetooth.service
}

w0() {
    rfkill block wifi
    nmcli radio wifi off
}

w1() {
    rfkill unblock wifi
    nmcli radio wifi on
}

# van is like man but in vim
van() { man "$@" 2>/dev/null | col -b | vim -; }

eval "$(zoxide init posix --hook prompt)"
